# Mapbox GL access token (required)
# Get one at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=pk.your_token_here

# URL to the WDPA PMTiles file (required)
# Production: a public CDN URL (Cloudflare R2, S3, etc.) that supports HTTP
# range requests and CORS for your origin.
# Local dev: serve spatialData/ with a range-capable static server, e.g.
#   npx serve ~/Documents/PRJ/2026/spatialData -l 8080 --cors
VITE_PMTILES_URL=https://pub-<hash>.r2.dev/wdpa.pmtiles
